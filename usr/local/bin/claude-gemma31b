#!/usr/bin/env bash
set -e

docker run --rm -it \
  --network host \
  -e ANTHROPIC_BASE_URL=http://localhost:11434 \
  -e ANTHROPIC_AUTH_TOKEN=ollama \
  -e ANTHROPIC_API_KEY="" \
  -e ANTHROPIC_DEFAULT_HAIKU_MODEL=gemma4:31b-64k-claude \
  -e ANTHROPIC_DEFAULT_SONNET_MODEL=gemma4:31b-64k-claude \
  -e ANTHROPIC_DEFAULT_OPUS_MODEL=gemma4:31b-64k-claude-claude \
  -v "$PWD:/workspace" \
  -v claude-code-config:/root/.claude \
  claude-code "$@"
