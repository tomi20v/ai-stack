#!/usr/bin/env bash
set -e

# Function to get available claude models from ollama
get_ollama_models() {
  if ! command -v ollama > /dev/null; then
    echo "Error: ollama is not installed or not in PATH." >&2
    exit 1
  fi
  mapfile -t models < <(ollama ls | grep claude | awk '{print $1}')
}

# Get current available models
get_ollama_models

if [[ ${#models[@]} -eq 0 ]]; then
  echo "No claude models found via ollama." >&2
  exit 1
fi

# Prepare selection list
options=("${models[@]}")

# Function to prompt user for model selection
select_model() {
  local choice=""
  if command -v fzf > /dev/null; then
    # Use fzf for visual selection
    choice=$(printf '%s\n' "${options[@]}" | fzf --prompt='Select claude model: ')
  else
    # Fzf not available, fallback to text prompt
    echo "fzf is not available. For best experience install fzf (e.g., apt install fzf)."
    echo "Available claude models:"
    for m in "${models[@]}"; do
      echo "  $m"
    done
    read -rp "Enter model name: " choice
  fi

  if [[ -z "$choice" ]]; then
    echo "Error: No model selected." >&2
    exit 1
  fi

  # Validate chosen model exists in list
  local found=false
  for m in "${models[@]}"; do
    if [[ "$m" == "$choice" ]]; then
      found=true
      break
    fi
  done

  if [[ "$found" = false ]]; then
    echo "Error: selected model '$choice' not found among available claude models." >&2
    exit 1
  fi

  # Export for later use
  SELECTED_MODEL="$choice"
}

# Run selection
select_model

# Set environment variables for Docker run
export ANTHROPIC_BASE_URL="http://localhost:11434"
export ANTHROPIC_AUTH_TOKEN=ollama
export ANTHROPIC_API_KEY=""
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$SELECTED_MODEL"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$SELECTED_MODEL"
export ANTHROPIC_DEFAULT_OPUS_MODEL="$SELECTED_MODEL"

# Run the claude-code container with passed arguments

docker run --rm -it \
  --network host \
  -e ANTHROPIC_BASE_URL=$ANTHROPIC_BASE_URL \
  -e ANTHROPIC_AUTH_TOKEN=$ANTHROPIC_AUTH_TOKEN \
  -e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY \
  -e ANTHROPIC_DEFAULT_HAIKU_MODEL=$ANTHROPIC_DEFAULT_HAIKU_MODEL \
  -e ANTHROPIC_DEFAULT_SONNET_MODEL=$ANTHROPIC_DEFAULT_SONNET_MODEL \
  -e ANTHROPIC_DEFAULT_OPUS_MODEL=$ANTHROPIC_DEFAULT_OPUS_MODEL \
  -v "$PWD:/workspace" \
  -v claude-code-config:/root/.claude \
  claude-code "$@"
