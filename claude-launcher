#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(pwd)"

get_ollama_models() {
  if ! command -v ollama >/dev/null 2>&1; then
    echo "Error: ollama is not installed or not in PATH." >&2
    exit 1
  fi

  mapfile -t models < <(
    ollama list |
      awk 'NR > 1 && tolower($1) ~ /claude/ {print $1}' |
      sort -u
  )
}

select_model() {
  local choice=""

  if command -v fzf >/dev/null 2>&1; then
    choice="$(
      printf '%s\n' "${models[@]}" |
        fzf --prompt='Select Claude model: '
    )"
  else
    echo "Available Claude models:"
    printf '  %s\n' "${models[@]}"
    read -rp "Enter model name: " choice
  fi

  if [[ -z "$choice" ]]; then
    echo "Error: no model selected." >&2
    exit 1
  fi

  if ! printf '%s\n' "${models[@]}" | grep -Fxq -- "$choice"; then
    echo "Error: '$choice' is not among the available Claude models." >&2
    exit 1
  fi

  SELECTED_MODEL="$choice"
}

get_ollama_models

if [[ ${#models[@]} -eq 0 ]]; then
  echo "No Ollama models containing 'claude' were found." >&2
  exit 1
fi

select_model

# Ensure claude-code is available on the host
if ! command -v claude >/dev/null 2>&1; then
  echo "Error: claude-code is not installed or not in PATH." >&2
  exit 1
fi

# Run claude-code directly with the selected model environment variables
#env ANTHROPIC_BASE_URL=http://localhost:11434 \
env ANTHROPIC_BASE_URL=http://localhost:11435 \
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_API_KEY="" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="${SELECTED_MODEL}" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="${SELECTED_MODEL}" \
    ANTHROPIC_DEFAULT_OPUS_MODEL="${SELECTED_MODEL}" \
    claude "$@"
