#!/usr/bin/env bash
set -e

# Function to get available copilot models from ollama
get_ollama_models() {
  if ! command -v ollama > /dev/null; then
    echo "Error: ollama is not installed or not in PATH." >&2
    exit 1
  fi
  mapfile -t models < <(ollama ls | grep copilot | awk '{print $1}' | sort)
}

# Get current available models
get_ollama_models

if [[ ${#models[@]} -eq 0 ]]; then
  echo "No copilot models found via ollama." >&2
  exit 1
fi

# Prepare selection list
options=("${models[@]}")

# Function to prompt user for model selection
select_model() {
  local choice=""
  if command -v fzf > /dev/null; then
    # Use fzf for visual selection
    choice=$(printf '%s\n' "${options[@]}" | fzf --prompt='Select copilot model: ')
  else
    # Fzf not available, fallback to text prompt
    echo "fzf is not available. For best experience install fzf (e.g., apt install fzf)."
    echo "Available copilot models:"
    for m in "${models[@]}"; do
      echo "  $m"
    done
    read -rp "Enter model name: " choice
  fi

  if [[ -z "$choice" ]]; then
    echo "Error: No model selected." >&2
    exit 1
  fi

  # Validate chosen model exists in list
  local found=false
  for m in "${models[@]}"; do
    if [[ "$m" == "$choice" ]]; then
      found=true
      break
    fi
  done

  if [[ "$found" = false ]]; then
    echo "Error: selected model '$choice' not found among available copilot models." >&2
    exit 1
  fi

  # Export for later use
  SELECTED_MODEL="$choice"
}

# Run selection
select_model

# Set environment variables for Docker run
export COPILOT_PROVIDER_BASE_URL="http://localhost:11434/v1"
export COPILOT_PROVIDER_TYPE="openai"
export COPILOT_MODEL="$SELECTED_MODEL"
export COPILOT_OFFLINE="true"
export COPILOT_HOME="/root/.copilot"
export COPILOT_PROVIDER_API_KEY="ollama"

# Run the copilot-cli container with passed arguments

docker run --rm -it \
  --network host \
  -e COPILOT_PROVIDER_BASE_URL=$COPILOT_PROVIDER_BASE_URL \
  -e COPILOT_PROVIDER_TYPE=$COPILOT_PROVIDER_TYPE \
  -e COPILOT_MODEL=$COPILOT_MODEL \
  -e COPILOT_OFFLINE=$COPILOT_OFFLINE \
  -e COPILOT_HOME=$COPILOT_HOME \
  -e COPILOT_PROVIDER_API_KEY=$COPILOT_PROVIDER_API_KEY \
  -v "$PWD:/workspace" \
  -v copilot-cli-config:/root/.copilot \
  github-copilot-cli "$@"
