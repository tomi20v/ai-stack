#!/usr/bin/env bash
set -euo pipefail

USER_ID="$(id -u)"
GROUP_ID="$(id -g)"
PROJECT_DIR="$(pwd)"

get_ollama_models() {
  if ! command -v ollama >/dev/null 2>&1; then
    echo "Error: ollama is not installed or not in PATH." >&2
    exit 1
  fi

  mapfile -t models < <(
    ollama list |
      awk 'NR > 1 && tolower($1) ~ /copilot/ {print $1}' |
      sort -u
  )
}

select_model() {
  local choice=""

  if command -v fzf >/dev/null 2>&1; then
    choice="$(
      printf '%s\n' "${models[@]}" |
        fzf --prompt='Select Copilot model: '
    )"
  else
    echo "Available Copilot models:"
    printf '  %s\n' "${models[@]}"
    read -rp "Enter model name: " choice
  fi

  if [[ -z "$choice" ]]; then
    echo "Error: no model selected." >&2
    exit 1
  fi

  if ! printf '%s\n' "${models[@]}" | grep -Fxq -- "$choice"; then
    echo "Error: '$choice' is not among the available Copilot models." >&2
    exit 1
  fi

  SELECTED_MODEL="$choice"
}

get_ollama_models

if [[ ${#models[@]} -eq 0 ]]; then
  echo "No Ollama models containing 'copilot' were found." >&2
  exit 1
fi

select_model

# Project-specific persistent Copilot data.
mkdir -p \
  "${PROJECT_DIR}/.copilot/.cache" \
  "${PROJECT_DIR}/.copilot/.config"

if [[ ! -w "${PROJECT_DIR}/.copilot" ]]; then
  echo "Error: ${PROJECT_DIR}/.copilot is not writable by the current user." >&2
  echo "Fix it with:" >&2
  echo "  sudo chown -R ${USER_ID}:${GROUP_ID} '${PROJECT_DIR}/.copilot'" >&2
  exit 1
fi

docker run --rm -it \
  --user "${USER_ID}:${GROUP_ID}" \
  --network host \
  --workdir /workspace \
  --env HOME=/workspace \
  --env COPILOT_HOME=/workspace/.copilot \
  --env XDG_CACHE_HOME=/workspace/.copilot/.cache \
  --env XDG_CONFIG_HOME=/workspace/.copilot/.config \
  --env COPILOT_PROVIDER_BASE_URL=http://localhost:11434/v1 \
  --env COPILOT_PROVIDER_TYPE=openai \
  --env COPILOT_MODEL="${SELECTED_MODEL}" \
  --env COPILOT_OFFLINE=true \
  --env COPILOT_PROVIDER_API_KEY=ollama \
  --mount "type=bind,source=${PROJECT_DIR},target=/workspace" \
  github-copilot-cli "$@"

