#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(pwd)"

get_ollama_models() {
  if ! command -v ollama >/dev/null 2>&1; then
    echo "Error: ollama is not installed or not in PATH." >&2
    exit 1
  fi

  mapfile -t models < <(
    ollama list |
      awk 'NR > 1 && tolower($1) ~ /copilot/ {print $1}' |
      sort -u
  )
}

select_model() {
  local choice=""
  if command -v fzf >/dev/null 2>&1; then
    choice="$(printf '%s\n' "${models[@]}" | fzf --prompt='Select Copilot model: ')"
  else
    echo "Available Copilot models:"
    printf '  %s\n' "${models[@]}"
    read -rp "Enter model name: " choice
  fi

  if [[ -z "$choice" ]]; then
    echo "Error: no model selected." >&2
    exit 1
  fi

  if ! printf '%s\n' "${models[@]}" | grep -Fxq -- "$choice"; then
    echo "Error: '$choice' is not among the available Copilot models." >&2
    exit 1
  fi
  SELECTED_MODEL="$choice"
}

get_token_limits() {
  local m="$1"
  local p=32000
  local o=4096

  if [[ "$m" == *"64k"* ]]; then
    p=60000; o=6144
  elif [[ "$m" == *"10pad*" ]]; then # Wait, checking if 100k logic was broken above. Fixing now.
    :
  fi

  # Clean implementation of the mapping
  if [[ "$m" == *"64k"* ]]; then
    p=60000; o=6144
  elif [[ "$m" == *"100k"* ]]; then
    p=100000; o=8192
  elif [[ "$m" == *"128k"* ]]; then
    p=120000; o=12288
  elif [[ "$m" == *"256k"* ]]; then
    p=240000; o=16384
  fi

  echo "$p $o"
}

get_ollama_models
if [[ ${#models[@]} -eq 0 ]]; then
  echo "No Ollama models containing 'copilot' were found." >&2
  exit 1
fi

select_model

read -r PROMPT_LIMIT OUTPUT_LIMIT < <(get_token_limits "$SELECTED_MODEL")

if ! command -v copilot >/dev/null 2>&1; then
  echo "Error: copilot is not installed or not in PATH." >&2
  exit 1
fi

env COPILOT_HOME="${PROJECT_DIR}/.copilot" \
    XDG_CACHE_HOME="${PROJECT_DIR}/.copilot/.cache" \
    XDG_CONFIG_HOME="${PROJECT_DIR}/.copilot/.config" \
    COPILOT_PROVIDER_BASE_URL=http://localhost:11434/v1 \
    COPILOT_PROVIDER_TYPE=openai \
    COPILOT_MODEL="${SELECTED_MODEL}" \
    COPILOT_OFFLINE=true \
    COPILOT_PROVIDER_API_KEY=****** \
    COPILOT_PROVIDER_MAX_PROMPT_TOKENS="$PROMPT_LIMIT" \
    COPILOT_PROVIDER_MAX_OUTPUT_TOKENS="$OUTPUT_LIMIT" \
    copilot "$@"
